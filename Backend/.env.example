# Backend/.env.example
#
# reactor-core's (and, where noted, auth-sidecar's) runtime env vars. Every
# default below matches `bin/reactor-core/src/main.rs`'s `env_or()` fallback
# — a bare `cargo run -p reactor-core` (or `cargo test --workspace`) FROM
# Backend/ boots with ZERO required env vars, against the dev
# `docker-compose` stack's published host ports (Postgres 15432, Redis
# 16379). None of these values are secrets except where noted — copy this
# file to `.env` (gitignored) and override only what your environment needs.
# Docker-level secrets (the envelope-encryption master key, `tower`'s own
# Postgres password) are documented separately in `Docker/.env.example`.

# --- Postgres --------------------------------------------------------------
# `app_role` (NOT `tower`, the superuser used by migrations/dev tooling) —
# reactor-core's production pool runs AS app_role so it is genuinely subject
# to row-level security (Fase 6a Task 9; see migration 0019's comment). The
# password after app_role: must match whatever you set once via
# `ALTER ROLE app_role PASSWORD '...'` (see Docker/.env.example's
# APP_ROLE_PASSWORD entry) — "app_role_dev_only" below is the dev-only
# default that convention documents, matching `tower`'s own
# "tower_dev_only" dev default.
DATABASE_URL=postgres://app_role:app_role_dev_only@127.0.0.1:15432/tower

# --- Redis -------------------------------------------------------------
REDIS_URL=redis://127.0.0.1:16379

# --- SPX / auth-sidecar --------------------------------------------------
SPX_BASE_URL=https://logistics.myagencyservice.id
AUTH_SIDECAR_URL=http://127.0.0.1:8082

# --- Tenant resolution (Fase 6a Task 9) -----------------------------------
# The single deployment tenant's `tenants.slug`. Required — unlike every
# other var here, there is no sensible default (a fresh dev DB has no seeded
# tenant to default to); an unset/unresolvable TENANT_SLUG is a boot-time
# misconfiguration and reactor-core will panic with a clear message rather
# than silently booting against the wrong (or no) tenant.
TENANT_SLUG=

# --- Envelope-encryption master key (Fase 3) ------------------------------
# Same convention Docker/docker-compose.yml's `tower-reactor-core`/
# `tower-auth-sidecar` services already set explicitly
# (TOWER_MASTER_KEY_PATH=/run/secrets/tower_master_key, the Compose
# file-secret mount point) — unset here, reactor-core falls back to the
# repo-relative `../Docker/secrets/tower_master_key` file for a host-run (not
# containerized) `cargo run`/`cargo test`, the same file
# Docker/.env.example's setup instructions have you create once:
#   mkdir -p Docker/secrets && openssl rand -out Docker/secrets/tower_master_key 32 && chmod 0400 Docker/secrets/tower_master_key
# TOWER_MASTER_KEY_PATH=/run/secrets/tower_master_key

# --- HTTP layer (Fase 6a Tasks 5-8) ---------------------------------------
# Comma-separated exact-match allowlist. Unset/empty = deny all origins (NOT
# a wildcard fallback) — see middleware::cors_layer's doc comment.
CORS_ALLOWED_ORIGINS=
# Session cookie's `Secure` attribute. Default true (production-safe); set
# false only for local dev that reaches reactor-core directly over plain
# HTTP (no TLS-terminating edge proxy in front of it).
COOKIE_SECURE=true
SESSION_COOKIE_NAME=spx_session

# --- Poller tuning (Fase 5, poller::PollerConfig::from_env) ---------------
# Optional — every one of these has a reference-matched default (see
# `poller::PollerConfig::default()`'s doc comment for the authoritative
# list/values, not duplicated here to avoid the two copies drifting):
#   SPX_POLL_INTERVAL_MS, SPX_PAGE_SIZE, SPX_MAX_PAGES, SPX_FULL_SYNC_EVERY,
#   SPX_FAST_DETECT_PAGES, SPX_SWEEP_HEDGE_MS, SPX_NOTIF_WATCH_MS,
#   SPX_NOTIF_WATCH_CONCURRENCY, PORTAL_USERNAME (the durable-primary
#   account's username — see poller::watchdog)
