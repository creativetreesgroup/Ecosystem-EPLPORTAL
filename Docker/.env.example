# Postgres dev password (local only). Everything sensitive beyond this — the
# envelope-encryption master key, SPX credentials, WAHA key — is NOT stored in
# .env. The master key is a Docker *file secret*:
#   mkdir -p Docker/secrets
#   openssl rand -out Docker/secrets/tower_master_key 32
#   chmod 0400 Docker/secrets/tower_master_key
# Docker/secrets/ is gitignored; back up tower_master_key out-of-band (losing it
# makes every stored ciphertext unrecoverable). Containers read it at
# /run/secrets/tower_master_key via the compose `secrets:` stanza.
POSTGRES_PASSWORD=tower_dev_only

# Password for `app_role` (Fase 6a Task 9): `tower` is a Postgres superuser
# and unconditionally bypasses row-level security, so `reactor-core`'s own
# production pool connects as this restricted, RLS-observing role instead —
# never as `tower`. Migration 0019 only grants LOGIN capability (no password
# in git, per Aturan Keras #5); the password itself is set out-of-band, once,
# via (superuser-authenticated):
#   psql "$TOWER_SUPERUSER_DATABASE_URL" -c "ALTER ROLE app_role PASSWORD '$APP_ROLE_PASSWORD';"
# then reactor-core's own DATABASE_URL (see Backend/.env.example) uses this
# same value: postgres://app_role:$APP_ROLE_PASSWORD@<host>/tower
APP_ROLE_PASSWORD=app_role_dev_only

# Rust logging
RUST_LOG=info

# reactor-core's/auth-sidecar's full runtime env var list (DATABASE_URL,
# REDIS_URL, TENANT_SLUG, TOWER_MASTER_KEY_PATH, etc.) lives in
# Backend/.env.example, not here — this file only covers docker-compose's own
# top-level secrets/interpolation surface.
